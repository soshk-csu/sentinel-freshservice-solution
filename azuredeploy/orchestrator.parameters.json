{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "value": "YOUR-SENTINEL-WORKSPACE"
    },
    "workspaceId": {
      "value": "/subscriptions/YOUR-SUB-ID/resourceGroups/YOUR-RG/providers/Microsoft.OperationalInsights/workspaces/YOUR-WORKSPACE"
    },
    "freshserviceDomain": {
      "value": "yourcompany.freshservice.com"
    },
    "freshserviceApiKey": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/YOUR-SUB-ID/resourceGroups/YOUR-RG/providers/Microsoft.KeyVault/vaults/YOUR-BOOTSTRAP-KV"
        },
        "secretName": "FreshserviceApiKey"
      }
    },
    "clientId": {
      "value": "YOUR-APP-REGISTRATION-CLIENT-ID"
    },
    "clientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/YOUR-SUB-ID/resourceGroups/YOUR-RG/providers/Microsoft.KeyVault/vaults/YOUR-BOOTSTRAP-KV"
        },
        "secretName": "SentinelClientSecret"
      }
    },
    "keyVaultName": {
      "value": "YOUR-KEY-VAULT-NAME"
    },
    "deployerObjectId": {
      "value": "YOUR-OBJECT-ID"
    },
    "defaultRequesterEmail": {
      "value": "soc-automation@yourcompany.com"
    },
    "defaultGroupId": {
      "value": 0
    },
    "syncOnSeverity": {
      "value": ["High", "Medium"]
    },
    "incidentTagFilter": {
      "value": ""
    },
    "pollingIntervalMinutes": {
      "value": 5
    },
    "commentSyncIntervalMinutes": {
      "value": 10
    },
    "baseTemplateUri": {
      "value": "https://raw.githubusercontent.com/soshk-csu/sentinel-freshservice-solution/main"
    }
  }
}
