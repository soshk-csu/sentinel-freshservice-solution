{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Sentinel-Freshservice-KeyVault",
    "description": "Deploys the Azure Key Vault and stores all required secrets for the Sentinel-Freshservice connector. Uses RBAC access model (Key Vault Secrets User role) instead of legacy access policies."
  },
  "parameters": {
    "keyVaultName": {
      "type": "string",
      "defaultValue": "[concat('kv-sentfs-', uniqueString(resourceGroup().id))]",
      "maxLength": 24,
      "metadata": { "description": "Key Vault name (globally unique, 3-24 chars)." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "tenantId": {
      "type": "string",
      "defaultValue": "[subscription().tenantId]"
    },
    "freshserviceApiKey": {
      "type": "securestring",
      "metadata": { "description": "Freshservice API key." }
    },
    "sentinelClientSecret": {
      "type": "securestring",
      "metadata": { "description": "Azure AD App Registration client secret for Sentinel API access." }
    },
    "webhookSecret": {
      "type": "securestring",
      "defaultValue": "[newGuid()]",
      "metadata": { "description": "Basic Auth password shared with Freshservice's Workflow Automator 'Requires Authentication' webhook setting (username is the WebhookAuthUsername playbook parameter). Auto-generated if left blank." }
    },
    "deployerObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Object ID of the user/service-principal running this deployment, granted Key Vault Administrator role for initial setup. Leave blank to skip (e.g. portal wizard deploys that cannot look this up)." }
    },
    "logicApp1PrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Managed Identity principal ID of CreateTicket Logic App (Playbook 1). Leave blank to assign post-deploy." }
    },
    "logicApp2PrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Managed Identity principal ID of IncidentPoller Logic App (Playbook 2)." }
    },
    "logicApp3PrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Managed Identity principal ID of WebhookReceiver Logic App (Playbook 3)." }
    },
    "logicApp4PrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Managed Identity principal ID of SyncComments Logic App (Playbook 4)." }
    }
  },
  "variables": {
    "kvSecretsUserRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
    "kvAdminRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '00482a5a-887f-4fb3-b363-3b7fe8e74483')]"
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[parameters('tenantId')]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "enabledForDeployment": false,
        "enabledForTemplateDeployment": true,
        "enabledForDiskEncryption": false,
        "networkAcls": {
          "defaultAction": "Allow",
          "bypass": "AzureServices"
        }
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-02-01",
      "name": "[concat(parameters('keyVaultName'), '/FreshserviceApiKey')]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "value": "[parameters('freshserviceApiKey')]",
        "attributes": { "enabled": true },
        "contentType": "text/plain"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-02-01",
      "name": "[concat(parameters('keyVaultName'), '/SentinelClientSecret')]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "value": "[parameters('sentinelClientSecret')]",
        "attributes": { "enabled": true },
        "contentType": "text/plain"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-02-01",
      "name": "[concat(parameters('keyVaultName'), '/FreshserviceWebhookSecret')]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "value": "[parameters('webhookSecret')]",
        "attributes": { "enabled": true },
        "contentType": "text/plain"
      }
    },
    {
      "condition": "[not(empty(parameters('deployerObjectId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultName'), parameters('deployerObjectId'), 'kvadmin')]",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "roleDefinitionId": "[variables('kvAdminRoleId')]",
        "principalId": "[parameters('deployerObjectId')]",
        "principalType": "User"
      }
    },
    {
      "condition": "[not(empty(parameters('logicApp1PrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultName'), parameters('logicApp1PrincipalId'), 'la1-kvsecrets')]",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "roleDefinitionId": "[variables('kvSecretsUserRoleId')]",
        "principalId": "[parameters('logicApp1PrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "condition": "[not(empty(parameters('logicApp2PrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultName'), parameters('logicApp2PrincipalId'), 'la2-kvsecrets')]",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "roleDefinitionId": "[variables('kvSecretsUserRoleId')]",
        "principalId": "[parameters('logicApp2PrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "condition": "[not(empty(parameters('logicApp3PrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultName'), parameters('logicApp3PrincipalId'), 'la3-kvsecrets')]",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "roleDefinitionId": "[variables('kvSecretsUserRoleId')]",
        "principalId": "[parameters('logicApp3PrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "condition": "[not(empty(parameters('logicApp4PrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultName'), parameters('logicApp4PrincipalId'), 'la4-kvsecrets')]",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"],
      "properties": {
        "roleDefinitionId": "[variables('kvSecretsUserRoleId')]",
        "principalId": "[parameters('logicApp4PrincipalId')]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "keyVaultId": {
      "type": "string",
      "value": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))).vaultUri]"
    },
    "webhookSecretName": {
      "type": "string",
      "value": "FreshserviceWebhookSecret"
    }
  }
}
